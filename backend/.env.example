# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/projeto_point
# Para Railway PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@[HOST]:[PORT]/railway
# Para Supabase:
# DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://seu-app.vercel.app

# Environment
ENVIRONMENT=development
DEBUG=true

# Supabase (opcional, se usar auth do Supabase)
# SUPABASE_URL=https://[PROJECT_REF].supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
